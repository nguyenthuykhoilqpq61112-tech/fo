# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DATABASE_URL: SQLite database path used by the Express server.
# Example: sqlite:./data/app.sqlite
DATABASE_URL="sqlite:./data/app.sqlite"

# PORT: Full-stack Express server port for production.
PORT="3000"

# WORLD_CUP_2026_FEED_URL: Optional custom JSON feed for live World Cup 2026 matches.
# Expected response shape: { "matches": [...] }. When unset, the server uses ESPN's FIFA World Cup scoreboard.
WORLD_CUP_2026_FEED_URL=""

# WORLD_CUP_2026_ESPN_DATES: Optional ESPN date range(s) in YYYYMMDD-YYYYMMDD format.
# Use commas for multiple windows. When unset, the server fetches full 2026 World Cup history
# plus current/future knockout windows so the board includes earlier rounds and upcoming matches.
WORLD_CUP_2026_ESPN_DATES=""

# WORLD_CUP_2026_DISABLE_ESPN: Set to "true" to skip ESPN and use only the custom feed/fallback.
WORLD_CUP_2026_DISABLE_ESPN=""
